# Ignore uploaded temp files
static/uploads/*

# Ignore recommendation images (large product catalog, managed separately)
static/recommendations/*

# Ignore Python cache and compiled files
__pycache__/
*.pyc

# Ignore environment config
.env
*.env

# Ignore virtual environment
venv/
env/

# Ignore macOS system files recursively
**/.DS_Store

# Ignore Claude desktop app config
.claude/

# Ignore YOLO model weights (large binary files, downloaded automatically)
*.pt

# Ignore FAISS index and data directory (generated per-server from local images)
data/
